# ==================== CORS CONFIGURATION ====================
# Allowed origins for cross-origin requests
CORS_ORIGIN_LOCAL=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175
CORS_ORIGIN_PRODUCTION=https://azuno.com,https://azunotechnologies.com,https://admin.azuno.com
# Update for your production domain

# ==================== EMAIL (Optional - for contact notifications) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@azuno.com

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW=900000
# 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window
SMTP_PASS=your_app_password
NOTIFY_EMAIL=admin@azuno.tech

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
